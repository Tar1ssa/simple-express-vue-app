<%- include('partials/header', { title: 'Reset Password' }) %>

<div style="max-width: 400px; margin: 0 auto;">
    <div class="card">
        <h2 style="margin-bottom: 1rem; text-align: center;">Reset Password</h2>
        <p style="color: var(--text-muted); text-align: center; margin-bottom: 1.5rem; font-size: 0.9rem;">
            Enter the token from your email and your new password.
        </p>
        <form action="/reset-password" method="POST">
            <div class="form-group">
                <label>Reset Token</label>
                <input type="text" name="token" required placeholder="Enter token">
            </div>
            <div class="form-group">
                <label>New Password</label>
                <input type="password" name="newPassword" required placeholder="••••••••">
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">Reset Password</button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>
